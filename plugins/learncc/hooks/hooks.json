{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-context.sh\"",
            "timeout": 5,
            "once": true,
            "statusMessage": "Loading course progress..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cp \"$HOME/.claude/learncc/progress.json\" \"$HOME/.claude/learncc/progress.backup.json\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  }
}